{
  "expo": {
    "name": "Shadow Monarch",
    "slug": "shadow-monarch",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#05050c"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shadowmonarch.hunter"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05050c"
      },
      "package": "com.shadowmonarch.hunter"
    },
    "plugins": [
      "./plugins/withKotlinVersion"
    ]
  }
}
