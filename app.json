{
  "expo": {
    "name": "Shadow Monarch",
    "slug": "shadow-monarch",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0a",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shadowmonarch.hunter"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.shadowmonarch.hunter"
    },
    "plugins": [
      ["expo-build-properties", { "android": { "kotlinVersion": "1.9.25" } }],
      "./plugins/withKotlinVersion"
    ]
  }
}
